# Laravel Environment Configuration Example

APP_NAME=Laravel
APP_ENV=local
APP_KEY=base64:YOUR_APP_KEY_HERE
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=starradius
DB_USERNAME=starradius
DB_PASSWORD=YOUR_DATABASE_PASSWORD_HERE

CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

TIMEZONE=Asia/Makassar
CURRENCY=IDR